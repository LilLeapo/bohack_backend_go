JWT_SECRET=change-this-in-production
PORT=8080
ACCESS_TOKEN_TTL_MINUTES=720
DEFAULT_EVENT_SLUG=bohack-2026
DEFAULT_EVENT_TITLE=BoHack 2026
FRONTEND_BASE_URL=http://127.0.0.1:5173
ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
ATTACHMENT_DIR=./storage/registration_attachments
MAX_UPLOAD_MB=20
MAIL_MODE=console
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
VERIFICATION_CODE_EXPIRE_MINUTES=10
VERIFICATION_CODE_MIN_INTERVAL_SECONDS=60
REQUIRE_REGISTER_VERIFICATION=false
ATTENDANCE_CONFIRMATION_EXPIRE_HOURS=168

# Database driver: postgres (default) or sqlite
DB_DRIVER=postgres
# When DB_DRIVER=postgres: set DATABASE_URL or PG* vars (PGHOST/PGPORT/PGUSER/PGPASSWORD/PGDATABASE/PGSSLMODE)
# DATABASE_URL=postgres://user:pass@127.0.0.1:5432/bohack?sslmode=disable
# When DB_DRIVER=sqlite: set SQLITE_PATH (or DATABASE_URL with a file path)
# SQLITE_PATH=./bohack.db
